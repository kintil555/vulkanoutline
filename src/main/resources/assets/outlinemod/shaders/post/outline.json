{
    "targets": {
        "outline_buf": {}
    },
    "passes": [
        {
            "vertex_shader": "minecraft:core/screenquad",
            "fragment_shader": "outlinemod:post/outline",
            "inputs": [
                {
                    "sampler_name": "In",
                    "target": "minecraft:main"
                },
                {
                    "sampler_name": "InDepth",
                    "target": "minecraft:main",
                    "use_depth_buffer": true
                }
            ],
            "uniforms": {
                "OutlineConfig": [
                    {
                        "name": "OutlineColor",
                        "type": "vec4",
                        "value": [0.0, 0.0, 0.0, 1.0]
                    },
                    {
                        "name": "OutlineThickness",
                        "type": "float",
                        "value": [1.5]
                    },
                    {
                        "name": "DepthThreshold",
                        "type": "float",
                        "value": [0.0002]
                    }
                ]
            },
            "output": "minecraft:main"
        }
    ]
}
